<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:models="clr-namespace:The_Merlin.Models"
               x:TypeArguments="models:TodoItem"
               x:Class="The_Merlin.CustomControls.TodoItemDetailPopup">
    <Border StrokeThickness="0" 
            BackgroundColor="#1E1E1E" 
            Padding="20" 
            StrokeShape="RoundRectangle 20"
            WidthRequest="350">

        <VerticalStackLayout Spacing="15">
            <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">
                <Label Text="{Binding TodoDefText, StringFormat='Def: {0}'}" TextColor="{Binding Color}" FontSize="10"/>
                <Label Text="{Binding CompletionType}" FontSize="10" TextColor="DarkGray"/>
                <Label Text="{Binding Status}" FontSize="10" TextColor="DarkGray">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="InProgress">
                            <Setter Property="TextColor" Value="DarkSlateGrey"></Setter>
                        </DataTrigger>
                        <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Pending">
                            <Setter Property="TextColor" Value="Transparent"></Setter>
                        </DataTrigger>
                        <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Completed">
                            <Setter Property="TextColor" Value="DarkOliveGreen"></Setter>
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </HorizontalStackLayout>
            <Entry Text="{Binding TodoText}" 
                   Placeholder="Görev İsmi" 
                   TextColor="White" 
                   PlaceholderColor="Gray"/>

            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Label Text="Süre (dk):" VerticalOptions="Center" TextColor="Silver"/>
                <Entry Text="{Binding GetDefaultDurationInMinutes}" 
                       Keyboard="Numeric" 
                       WidthRequest="80"
                       VerticalOptions="Center"/>
                <Label Text="{Binding getTotalTimeString}" VerticalOptions="Center" TextColor="Silver" FontSize="12"></Label>
            </HorizontalStackLayout>
            
            <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">
                <Button Text="Kaydet" 
                    Clicked="TaskSaved" 
                    BackgroundColor="#6200EE" 
                    TextColor="White"
                    WidthRequest="100"/>

                <Button Text="Vazgeç" 
                    Clicked="OnCancelClicked" 
                    BackgroundColor="Transparent" 
                    TextColor="Gray"
                    WidthRequest="100"/>
            </HorizontalStackLayout>
            
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
